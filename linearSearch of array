import java.util.Scanner;

public class findindex1d {
    public static void main(String[]args){
        Scanner sc= new Scanner(System.in);
         System.out.println("enter number of elements: ");// inputing number of elements
        int n=sc.nextInt();

        int[]numbers=new int[n];// decalaration of array

        for(int i=0;i<n;i++){// inputting values
            System.out.println("enter numbers at index  "+i);
            numbers[i]=sc.nextInt();
        }

        System.out.println("enter numbers that you want to search  ");
        int x=sc.nextInt();

       //printing output
       boolean found = false;//flag
       for(int i=0;i<n;i++){//loop for searching values
            if(x==numbers[i]){
                System.out.println("The number  "+ x +" is found at index "+ i);
                found=true;
                break;

            }
            if(!found){ 
              System.out.println("The number numbers not found  ");  
            }
            /*if(found==false){ 
              System.out.println("The number numbers not found  ");  
            } */
          
    }   
}
}
